includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - src
        - database/factories
    level: 6
    ignoreErrors:
        -
            identifier: trait.unused
            path: src/Persistence/Concerns/HasConversations.php
        -
            identifier: trait.unused
            path: src/Persistence/Concerns/HasMemory.php
        -
            identifier: varTag.unresolvableType
            path: src/Persistence/Middleware/PersistConversation.php
        -
            identifier: varTag.unresolvableType
            path: src/Persistence/Middleware/WireMemory.php
