# Atlas Sandbox Environment Configuration

# Application
APP_NAME="Atlas Sandbox"
APP_ENV=local
APP_DEBUG=true

# ─── Provider API Keys ───────────────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_URL=https://api.openai.com/v1
OPENAI_ORGANIZATION=

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Gemini
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_API_KEY=

# xAI (Grok)
XAI_API_KEY=your-xai-api-key-here

# Cohere
COHERE_API_KEY=

# Jina
JINA_API_KEY=

# LM Studio (local)
LMSTUDIO_URL=http://localhost:1234/v1

# ─── Default Modality Settings ────────────────────────────────────────────────

ATLAS_TEXT_PROVIDER=openai
ATLAS_TEXT_MODEL=gpt-4o-mini
ATLAS_IMAGE_PROVIDER=openai
ATLAS_IMAGE_MODEL=dall-e-3
ATLAS_EMBED_PROVIDER=openai
ATLAS_EMBED_MODEL=text-embedding-3-small
ATLAS_MODERATE_PROVIDER=openai
ATLAS_MODERATE_MODEL=omni-moderation-latest
